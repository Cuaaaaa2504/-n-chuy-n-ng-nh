# ============================================================
# CineHunt Backend — Environment Variables
# Copy file này thành .env và điền giá trị thực
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=your_password_here
DB_DATABASE=CineHuntDB

# --- JWT ---
# Secret keys phải là chuỗi ngẫu nhiên dài (ít nhất 32 ký tự)
JWT_SECRET=change_me_to_a_random_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_random_secret_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# --- Server ---
PORT=3000

# --- CORS ---
# Danh sách origin được phép, ngăn cách bởi dấu phẩy
CORS_ORIGINS=http://localhost:3001,http://localhost:5173
