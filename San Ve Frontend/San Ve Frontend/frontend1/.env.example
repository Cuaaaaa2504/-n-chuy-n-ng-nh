# Base URL của backend (dùng bởi src/api/axiosClient.ts)
VITE_API_BASE_URL=http://localhost:3002

# ⚠️ src/hooks/useTickets.ts đang dùng biến KHÁC + port KHÁC.
# Cần thống nhất về VITE_API_BASE_URL, hoặc set đúng giá trị dưới đây:
VITE_API_URL=http://localhost:3002

# CHỈ dùng khi dev. KHÔNG BAO GIỜ set = true khi build production
# (src/routes/PrivateRoute.tsx sẽ bỏ qua toàn bộ kiểm tra đăng nhập)
VITE_BYPASS_AUTH=false
