# ─────────────────────────────────────────────────────────────────────────────
# Base URL của backend CineHunt (cinehunt-backend / Backend3)
#
# FIX Lỗi 1: giá trị cũ ở đây là http://localhost:3002 — SAI.
# `main.ts` của backend listen ở `process.env.PORT || 3000`, nên bất kỳ ai copy
# file này thành .env đều nhận cấu hình hỏng, và fallback hardcode trong
# axiosClient.ts cũng là 3002 nên không có cách nào chạy đúng.
#
# Nếu bạn đổi PORT ở backend thì phải sửa lại giá trị dưới đây cho khớp.
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000

# ⚠️ Chỉ còn src/hooks/useTickets.ts dùng biến này (và nó gọi endpoint
# /bookings/my-tickets — route KHÔNG tồn tại ở backend; route đúng là
# GET /bookings/my). Hook này hiện không được import ở đâu cả.
# Giữ biến ở đây cho tương thích, nhưng nên xoá hẳn useTickets.ts.
VITE_API_URL=http://localhost:3000

# CHỈ dùng khi dev. KHÔNG BAO GIỜ set = true khi build production
# (src/routes/PrivateRoute.tsx sẽ bỏ qua toàn bộ kiểm tra đăng nhập)
VITE_BYPASS_AUTH=false
